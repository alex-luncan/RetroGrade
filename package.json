{
  "name": "retrograde",
  "productName": "RetroGrade",
  "version": "1.0.0",
  "description": "APK Decompiler - Convert Android APK files to readable Java/Kotlin source code",
  "main": "dist/main/main.js",
  "author": {
    "name": "Luncan Alex",
    "url": "https://www.linkedin.com/in/alexluncan/"
  },
  "license": "MIT",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build:all": "npm run build && npm run build:renderer",
    "watch": "tsc -w",
    "package": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac"
  },
  "build": {
    "appId": "com.retrograde.app",
    "productName": "RetroGrade",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "jadx/**/*"
    ],
    "extraResources": [
      {
        "from": "jadx",
        "to": "jadx",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/xml2js": "^0.4.14",
    "css-loader": "^6.9.1",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
